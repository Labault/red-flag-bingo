# ============================================================================
# .env.prod.local — SECRETS DE PRODUCTION
# ============================================================================
# Ce fichier est ignoré par git. Sur le serveur :
#   1. Copier ce template : cp .env.prod.local.dist .env.prod.local
#   2. Remplir TOUTES les valeurs ci-dessous
#   3. NE JAMAIS commiter .env.prod.local
# ============================================================================

# Domaine de prod (sans https://, sans slash final)
# Ex: redflagbingo.fun
APP_DOMAIN=

# Email pour Let's Encrypt (recevra les alertes d'expiration de cert)
# NOTE : depuis la migration derrière le Caddy global externe, redflagbingo
# ne gère plus TLS lui-même — c'est le Caddy global qui s'occupe des certs.
# La variable est conservée pour compatibilité descendante mais n'est plus utilisée.
LETSENCRYPT_EMAIL=

# Secret Symfony : générer avec → openssl rand -hex 32
APP_SECRET=

# Base de données prod : choisir un user et un mdp robuste
# Ex: postgresql://rfb_prod:UN_MDP_SOLIDE@database:5432/rfb_prod?serverVersion=16&charset=utf8
DATABASE_URL=
POSTGRES_DB=rfb_prod
POSTGRES_USER=rfb_prod
POSTGRES_PASSWORD=

# Mercure : générer avec → openssl rand -hex 32
# IMPORTANT : la même valeur pour les 3, et DIFFÉRENTE de la dev
MERCURE_JWT_SECRET=
MERCURE_PUBLISHER_JWT_KEY=
MERCURE_SUBSCRIBER_JWT_KEY=

# Hash bcrypt du mot de passe admin
# Générer avec : docker compose -f compose.prod.yaml run --rm app bin/console app:admin:hash-password
# IMPORTANT : entourer la valeur avec des quotes simples (à cause des $ du hash bcrypt)
ADMIN_PASSWORD_HASH=
