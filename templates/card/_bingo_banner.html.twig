<div id="bingo-banner">
    {% if hasBingo %}
        <div class="bingo-ticket text-white text-center py-4 sm:py-6 px-3 sm:px-4 rounded-xl mb-6 sm:mb-8">
            <div class="text-5xl sm:text-6xl mb-1 sm:mb-2">🎉</div>
            <div class="text-3xl sm:text-4xl font-black tracking-widest">BINGO !</div>
            <div class="text-xs sm:text-sm mt-1.5 sm:mt-2 opacity-90 font-bold px-2">
                {% if bingoCount == 1 %}
                    Tu as aligné 5 cases. Bravo, tu as survécu.
                {% else %}
                    {{ bingoCount }} lignes alignées. Légende absolue. 🏆
                {% endif %}
            </div>
        </div>
    {% endif %}
</div>
