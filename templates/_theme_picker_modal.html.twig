{# Modale de sélection du thème — à inclure dans un parent `data-controller="theme-picker"` #}
<style>
    @keyframes theme-picker-pop-in {
        from { opacity: 0; transform: scale(0.92) translateY(10px); }
        to   { opacity: 1; transform: scale(1) translateY(0); }
    }
    .theme-picker-dialog[open] {
        animation: theme-picker-pop-in 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .theme-picker-dialog[open]::backdrop {
        animation: theme-picker-pop-in 0.25s ease-out;
    }
</style>
<dialog
    data-theme-picker-target="dialog"
    data-action="click->theme-picker#backdropClose"
    class="theme-picker-dialog backdrop:bg-black/60 backdrop:backdrop-blur-sm bg-transparent p-0 m-auto rounded-2xl sm:rounded-3xl max-w-2xl w-[94vw] outline-none"
>
    <div class="relative bg-gradient-to-br from-white via-rose-50 to-red-50 rounded-2xl sm:rounded-3xl shadow-2xl border-2 border-red-200 p-5 sm:p-8 md:p-10">

        {# Bouton de fermeture #}
        <button type="button" data-action="theme-picker#close" class="absolute top-3 right-3 sm:top-4 sm:right-4 w-9 h-9 sm:w-10 sm:h-10 flex items-center justify-center rounded-full bg-white/80 hover:bg-red-100 text-gray-500 hover:text-red-600 text-lg sm:text-xl font-bold transition-all duration-200 hover:scale-110 cursor-pointer shadow-md z-10" aria-label="Fermer">
            ✕
        </button>

        {# En-tête #}
        <div class="text-center mb-5 sm:mb-8 pr-8 sm:pr-0">
            <div class="text-4xl sm:text-5xl mb-1 sm:mb-2">🎯</div>
            <h2 class="text-xl sm:text-2xl md:text-3xl font-black text-red-700 mb-1 sm:mb-2">
                Choisis ton terrain de jeu
            </h2>
            <p class="text-xs sm:text-sm text-gray-500 italic">
                Chaque thème, ses propres red flags. Bonne chance.
            </p>
        </div>

        {# Grille de thèmes #}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2.5 sm:gap-3 max-h-[60vh] sm:max-h-[55vh] overflow-y-auto pr-1 -mr-1">
            {% for theme in themes %}
                <form method="post" action="{{ path('app_card_new', {themeSlug: theme.slug}) }}">
                    <button type="submit" class="group/card relative w-full flex items-center gap-3 sm:gap-4 px-4 sm:px-5 py-3 sm:py-4 bg-white border-2 border-red-100 rounded-xl sm:rounded-2xl shadow-sm hover:shadow-lg hover:border-red-300 hover:bg-rose-50 hover:ring-4 hover:ring-red-100 active:scale-[0.98] transition-all duration-200 cursor-pointer text-left">
                        <span class="text-2xl sm:text-3xl group-hover/card:scale-110 group-hover/card:rotate-6 transition-transform duration-300">{{ theme.emoji }}</span>
                        <span class="flex-1 min-w-0">
                            <span class="block text-sm sm:text-base font-black text-gray-800 group-hover/card:text-red-700 transition-colors truncate">{{ theme.name }}</span>
                            <span class="block text-[10px] sm:text-[11px] uppercase tracking-wider text-gray-400 group-hover/card:text-red-500 font-bold transition-colors">Lancer une partie</span>
                        </span>
                        <span class="text-base sm:text-lg text-red-400 group-hover/card:text-red-600 group-hover/card:translate-x-1 transition-all duration-300">→</span>
                    </button>
                </form>
            {% endfor %}
        </div>
    </div>
</dialog>
