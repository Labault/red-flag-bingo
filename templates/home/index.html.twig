{% extends 'base.html.twig' %}

{% block title %}Red Flag Bingo — Le jeu qu'on aurait préféré ne jamais devoir inventer{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        @keyframes float-flag {
            0%, 100% { transform: translateY(0) rotate(-5deg); }
            50% { transform: translateY(-30px) rotate(5deg); }
        }
        @keyframes float-flag-alt {
            0%, 100% { transform: translateY(0) rotate(8deg); }
            50% { transform: translateY(-20px) rotate(-8deg); }
        }
        .floating-flag {
            position: absolute;
            font-size: 2.25rem;
            opacity: 0.12;
            animation: float-flag 6s ease-in-out infinite;
            user-select: none;
            pointer-events: none;
        }
        @media (min-width: 640px) {
            .floating-flag {
                font-size: 4rem;
                opacity: 0.15;
            }
        }
        .floating-flag.alt {
            animation: float-flag-alt 7s ease-in-out infinite;
        }
        @keyframes pulse-cta {
            0%, 100% { box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.5); }
            50% { box-shadow: 0 0 0 20px rgba(220, 38, 38, 0); }
        }
        .cta-pulse {
            animation: pulse-cta 2s infinite;
        }
        @keyframes ping-slow {
            0% { transform: scale(1); opacity: 0.5; }
            75%, 100% { transform: scale(1.15); opacity: 0; }
        }
        .animate-ping-slow {
            animation: ping-slow 2.5s cubic-bezier(0, 0, 0.2, 1) infinite;
        }
    </style>
{% endblock %}

{% block body %}
<div class="relative min-h-screen overflow-hidden bg-gradient-to-br from-red-50 via-pink-50 to-rose-100">

    {# 🚩 Drapeaux flottants en background — certains masqués sur mobile pour aérer #}
    <div class="floating-flag" style="top: 10%; left: 8%;">🚩</div>
    <div class="floating-flag alt" style="top: 15%; right: 8%; animation-delay: 1s;">🚩</div>
    <div class="floating-flag hidden sm:block" style="top: 60%; left: 5%; animation-delay: 2s;">🚩</div>
    <div class="floating-flag alt" style="top: 70%; right: 6%; animation-delay: 0.5s;">🚩</div>
    <div class="floating-flag hidden sm:block" style="top: 35%; left: 15%; animation-delay: 3s; font-size: 2.5rem;">🚩</div>
    <div class="floating-flag alt hidden sm:block" style="top: 80%; left: 50%; animation-delay: 1.5s; font-size: 3rem;">🚩</div>
    <div class="floating-flag hidden sm:block" style="top: 25%; right: 25%; animation-delay: 2.5s; font-size: 2rem;">🚩</div>

    {# Contenu principal #}
    <div class="relative z-10 min-h-screen flex flex-col items-center justify-center px-4 py-8 sm:py-12">

        <div class="text-center max-w-2xl w-full">

            {# Titre #}
            <div class="text-6xl sm:text-7xl md:text-8xl mb-3 sm:mb-4">🚩</div>
            <h1 class="text-4xl sm:text-5xl md:text-7xl font-black text-red-700 mb-3 sm:mb-4 tracking-tight">
                Red Flag <span class="text-pink-600">Bingo</span>
            </h1>

            {# Tagline #}
            <p class="text-base sm:text-xl md:text-2xl text-gray-700 font-medium mb-2 sm:mb-3 px-1">
                Le jeu qu'on aurait préféré ne jamais devoir inventer.
            </p>
            <p class="text-sm sm:text-base md:text-lg text-gray-500 mb-8 sm:mb-10 italic px-2">
                Coche les pires comportements en temps réel. Aligne 5 cases. Gagne.
            </p>

            {# CTA #}
            {% if themes|length > 0 %}
                <div data-controller="theme-picker">
                    <button type="button" data-action="theme-picker#open" class="group relative inline-flex items-center justify-center gap-2 sm:gap-3 px-7 sm:px-12 py-4 sm:py-6 text-base sm:text-xl md:text-2xl font-black text-white rounded-full overflow-hidden transition-all duration-300 hover:scale-105 active:scale-95 shadow-2xl cursor-pointer max-w-full">
                        {# Fond animé en gradient #}
                        <span class="absolute inset-0 bg-gradient-to-r from-red-600 via-pink-600 to-rose-600 transition-transform duration-500 group-hover:scale-110"></span>

                        {# Effet de brillance qui passe au hover #}
                        <span class="absolute inset-0 bg-gradient-to-r from-transparent via-white/30 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700"></span>

                        {# Halo pulsant en permanence #}
                        <span class="absolute inset-0 rounded-full ring-4 ring-red-400/40 animate-ping-slow"></span>

                        {# Contenu #}
                        <span class="relative z-10 flex items-center gap-2 sm:gap-3">
                            <span class="text-xl sm:text-3xl group-hover:rotate-12 transition-transform duration-300">🎲</span>
                            <span>Lancer une partie</span>
                            <span class="text-lg sm:text-2xl group-hover:translate-x-1 transition-transform duration-300">→</span>
                        </span>
                    </button>

                    {{ include('_theme_picker_modal.html.twig') }}
                </div>
            {% else %}
                <p class="text-red-600 font-semibold text-sm sm:text-base px-2">
                    ⚠️ Aucun thème disponible. Lance <code class="text-xs">php bin/console app:theme:import path/to.yml</code>.
                </p>
            {% endif %}

            {# Mini explication en bas #}
            <div class="mt-10 sm:mt-16 text-xs sm:text-sm text-gray-400 max-w-md mx-auto leading-relaxed px-2">
                <p>
                    Date, mariage, repas de famille, réunion de boulot, ... : certaines situations sont des champs de mines.
                    <br><br>
                    Génère une carte de bingo, coche les drapeaux rouges au fur et à mesure, et partage le lien à tes potes pour jouer en équipe.
                </p>
            </div>

        </div>
    </div>
</div>
{% endblock %}
