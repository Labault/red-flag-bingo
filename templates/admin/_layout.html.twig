{% extends 'admin/base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .pop-button-danger {
            background: #fee2e2;
            color: #b91c1c;
            border: 2px solid #b91c1c;
            transition: all 0.15s;
            font-weight: 700;
            padding: 6px 14px;
            border-radius: 6px;
            font-size: 0.75rem;
            cursor: pointer;
            display: inline-block;
            text-decoration: none;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .pop-button-danger:hover {
            background: #b91c1c;
            color: white;
        }

        /* Badge "ADMIN" — étiquette type slug-tag de l'app */
        .admin-badge {
            border: 2px dashed #db2777;
            padding: 1px 8px;
            font-family: 'Courier New', monospace;
            font-weight: bold;
            color: #db2777;
            font-size: 0.65rem;
            letter-spacing: 0.1em;
            transform: rotate(-2deg);
        }

        /* Items de nav — base sobre, hover scrapbook */
        .admin-nav-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 8px 14px;
            border-radius: 8px;
            border: 2px solid transparent;
            color: #374151;
            font-weight: 600;
            font-size: 0.875rem;
            white-space: nowrap;
            transition: all 0.15s;
        }
        @media (min-width: 1024px) {
            .admin-nav-item { gap: 0.75rem; }
        }
        .admin-nav-item:hover {
            background: white;
            border-color: #1f2937;
            transform: translate(-1px, -1px);
            box-shadow: 3px 3px 0 #1f2937;
        }

        /* Item actif — tampon scrapbook (rose, bordure noire, ombre, rotation subtile) */
        .admin-nav-item-active,
        .admin-nav-item-active:hover {
            background: #fce7f3;
            border-color: #1f2937;
            color: #be185d;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            transform: rotate(-0.6deg);
            box-shadow: 3px 3px 0 #1f2937;
        }
    </style>
{% endblock %}

{% block admin_body %}
<div class="flex flex-col lg:flex-row min-h-screen">

    {# Sidebar — top bar sur mobile, sidebar verticale en lg+ #}
    <aside class="lg:w-64 lg:shrink-0 bg-white border-b-2 lg:border-b-0 lg:border-r-2 border-gray-900 px-4 py-3 lg:p-6 flex flex-row lg:flex-col items-center lg:items-stretch gap-3 lg:gap-0 sticky top-0 lg:static z-30">
        <a href="{{ path('app_admin_dashboard') }}" class="block shrink-0 lg:mb-8">
            <div class="text-xl lg:text-2xl font-black text-gray-900">🚩 RFB</div>
            <span class="admin-badge hidden lg:inline-block mt-2">Admin</span>
        </a>

        <nav class="flex-1 flex flex-row lg:flex-col gap-2 overflow-x-auto lg:overflow-visible -mx-1 px-1 lg:mx-0 lg:px-0 py-1">
            {% set nav = [
                { route: 'app_admin_dashboard', label: 'Dashboard', icon: '🎛️' },
                { route: 'app_admin_themes_index', label: 'Thèmes', icon: '🎴' },
                { route: 'app_admin_imports_index', label: 'Imports', icon: '📥' }
            ] %}
            {% for item in nav %}
                {% set isActive = app.request.attributes.get('_route') starts with item.route %}
                <a href="{{ path(item.route) }}"
                   class="admin-nav-item shrink-0{% if isActive %} admin-nav-item-active{% endif %}">
                    <span class="text-base lg:text-lg">{{ item.icon }}</span>
                    <span>{{ item.label }}</span>
                </a>
            {% endfor %}
        </nav>

        <a href="{{ path('app_admin_logout') }}"
           class="pop-button-danger shrink-0 lg:mt-4 whitespace-nowrap text-center">
            <span class="lg:hidden">↪ Sortir</span>
            <span class="hidden lg:inline">← Déconnexion</span>
        </a>
    </aside>

    {# Main content #}
    <main class="flex-1 p-4 sm:p-6 lg:p-8 overflow-x-hidden min-w-0">
        {# Flash messages #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-3 sm:px-4 py-2.5 sm:py-3 rounded-lg border-2 font-medium text-sm sm:text-base
                            {% if type == 'success' %}bg-green-50 border-green-500 text-green-700
                            {% elseif type == 'error' %}bg-red-50 border-red-500 text-red-700
                            {% else %}bg-blue-50 border-blue-500 text-blue-700{% endif %}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {% block admin_content %}{% endblock %}
    </main>

</div>
{% endblock %}
